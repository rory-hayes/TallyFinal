generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum OrganizationRole {
  admin
  reviewer
  operator
  viewer
}

enum PayRunStatus {
  draft
  collecting_files
  ready_for_import
  archived
}

enum SourceFileKind {
  current_payroll
  previous_payroll
  journal
  payment
}

enum SourceFileStatus {
  registered
  uploaded
  superseded
}

enum SourceFilePreviewStatus {
  pending
  ready
  failed
}

enum EmployeeRecordScope {
  current
  previous
}

enum EmployeePayComponentCategory {
  earning
  deduction
  employer_cost
  other
}

enum EmployeeMatchMethod {
  exact_identifier
  manual
  unmatched
}

enum RuleResultStatus {
  passed
  failed
}

enum RuleResultSeverity {
  info
  warning
  blocker
}

enum ReviewExceptionStatus {
  open
  in_review
  resolved
  dismissed
}

enum ExceptionCommentType {
  comment
  audit_log
}

enum ApprovalEventType {
  submitted
  approved
  rejected
  reopened
}

enum ReviewProcessingRunStatus {
  queued
  processing
  completed
  failed
}

enum ReconciliationCheckKind {
  payroll_to_journal
  payroll_to_payment
}

enum ReconciliationCheckStatus {
  matched
  within_tolerance
  mismatch
}

model Organization {
  id                 String               @id @default(cuid())
  name               String
  slug               String               @unique
  createdByUserId    String
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  members            OrganizationMember[]
  clients            Client[]
  payRuns            PayRun[]
  sourceFiles        SourceFile[]
  mappingTemplates   MappingTemplate[]
  sourceColumnMappings SourceColumnMapping[]
  employeeRunRecords EmployeeRunRecord[]
  employeePayComponents EmployeePayComponent[]
  sourceRowRefs      SourceRowRef[]
  employeeMatches    EmployeeMatch[]
  ruleResults        RuleResult[]
  reviewExceptions   ReviewException[]
  exceptionComments  ExceptionComment[]
  approvalEvents     ApprovalEvent[]
  reviewProcessingRuns ReviewProcessingRun[]
  journalEntries     JournalEntry[]
  paymentRecords     PaymentRecord[]
  reconciliationChecks ReconciliationCheck[]
}

model OrganizationMember {
  id             String           @id @default(cuid())
  organizationId String
  userId         String
  email          String?
  displayName    String?
  role           OrganizationRole
  joinedAt       DateTime         @default(now())
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([userId])
  @@index([organizationId, role])
}

model Client {
  id                   String       @id @default(cuid())
  organizationId       String
  name                 String
  slug                 String
  legalName            String?
  countryCode          String       @default("IE")
  notes                String?
  createdByUserId      String
  updatedByUserId      String?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  archivedAt           DateTime?
  organization         Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  payRuns              PayRun[]
  sourceFiles          SourceFile[]
  mappingTemplates     MappingTemplate[]
  employeeRunRecords   EmployeeRunRecord[]
  employeePayComponents EmployeePayComponent[]
  sourceRowRefs        SourceRowRef[]
  employeeMatches      EmployeeMatch[]
  ruleResults          RuleResult[]
  reviewExceptions     ReviewException[]
  exceptionComments    ExceptionComment[]
  approvalEvents       ApprovalEvent[]
  reviewProcessingRuns ReviewProcessingRun[]
  journalEntries       JournalEntry[]
  paymentRecords       PaymentRecord[]
  reconciliationChecks ReconciliationCheck[]

  @@unique([organizationId, slug])
  @@unique([id, organizationId])
  @@index([organizationId, archivedAt])
  @@index([organizationId, name])
}

model PayRun {
  id                   String       @id @default(cuid())
  organizationId       String
  clientId             String
  title                String
  periodStart          DateTime
  periodEnd            DateTime
  payDate              DateTime?
  status               PayRunStatus @default(draft)
  activeReviewSnapshotVersion Int   @default(0)
  createdByUserId      String
  updatedByUserId      String?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  archivedAt           DateTime?
  organization         Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client               Client       @relation(fields: [clientId, organizationId], references: [id, organizationId], onDelete: Cascade)
  sourceFiles          SourceFile[]
  employeeRunRecords   EmployeeRunRecord[]
  employeePayComponents EmployeePayComponent[]
  sourceRowRefs        SourceRowRef[]
  employeeMatches      EmployeeMatch[]
  ruleResults          RuleResult[]
  reviewExceptions     ReviewException[]
  exceptionComments    ExceptionComment[]
  approvalEvents       ApprovalEvent[]
  reviewProcessingRuns ReviewProcessingRun[]
  journalEntries       JournalEntry[]
  paymentRecords       PaymentRecord[]
  reconciliationChecks ReconciliationCheck[]

  @@unique([id, organizationId])
  @@index([organizationId, clientId, archivedAt])
  @@index([clientId, status])
  @@index([organizationId, status])
}

model SourceFile {
  id                 String           @id @default(cuid())
  organizationId     String
  clientId           String
  payRunId           String
  kind               SourceFileKind
  status             SourceFileStatus @default(registered)
  originalFilename   String
  storageBucket      String
  storagePath        String
  contentType        String?
  byteSize           Int?
  checksumSha256     String
  version            Int
  replacementOfId    String?
  uploadedByUserId   String
  uploadedAt         DateTime?
  previewStatus      SourceFilePreviewStatus @default(pending)
  previewSheetName   String?
  previewHeaders     Json?
  previewSampleRows Json?
  previewRowCount    Int?
  previewError       String?
  importProfileKey   String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  organization       Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client             Client           @relation(fields: [clientId, organizationId], references: [id, organizationId], onDelete: Cascade)
  payRun             PayRun           @relation(fields: [payRunId, organizationId], references: [id, organizationId], onDelete: Cascade)
  replacementOf      SourceFile?      @relation("SourceFileReplacementChain", fields: [replacementOfId], references: [id], onDelete: SetNull)
  replacements       SourceFile[]     @relation("SourceFileReplacementChain")
  sourceColumnMappings SourceColumnMapping[]
  employeeRunRecords EmployeeRunRecord[]
  employeePayComponents EmployeePayComponent[]
  sourceRowRefs      SourceRowRef[]
  journalEntries     JournalEntry[]
  paymentRecords     PaymentRecord[]
  reconciliationChecks ReconciliationCheck[]

  @@unique([id, payRunId])
  @@unique([payRunId, kind, version])
  @@unique([storageBucket, storagePath])
  @@index([organizationId, payRunId, kind])
  @@index([payRunId, status])
  @@index([replacementOfId])
}

model MappingTemplate {
  id               String         @id @default(cuid())
  organizationId   String
  clientId         String
  sourceKind       SourceFileKind
  importProfileKey String
  templateName     String
  columnMappings   Json
  sourceHeaders    Json?
  createdByUserId  String
  updatedByUserId  String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  archivedAt       DateTime?
  organization     Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client           Client         @relation(fields: [clientId, organizationId], references: [id, organizationId], onDelete: Cascade)

  @@unique([organizationId, clientId, sourceKind, importProfileKey])
  @@index([organizationId, clientId, archivedAt])
}

model SourceColumnMapping {
  id             String       @id @default(cuid())
  organizationId String
  sourceFileId   String
  targetFieldKey String
  sourceHeader   String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  sourceFile     SourceFile   @relation(fields: [sourceFileId], references: [id], onDelete: Cascade)

  @@unique([sourceFileId, targetFieldKey])
  @@index([organizationId, sourceFileId])
}

/// Canonical employee-level review record. Pay-run summaries are not canonical review state.
model EmployeeRunRecord {
  id                  String              @id @default(cuid())
  organizationId      String
  clientId            String
  payRunId            String
  sourceFileId        String
  recordScope         EmployeeRecordScope
  reviewSnapshotVersion Int               @default(0)
  sourceRowNumber     Int
  employeeExternalId  String?
  employeeNumber      String?
  employeeDisplayName String
  grossPay            Decimal?            @db.Decimal(18, 2)
  netPay              Decimal?            @db.Decimal(18, 2)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  organization        Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client              Client              @relation(fields: [clientId, organizationId], references: [id, organizationId], onDelete: Cascade)
  payRun              PayRun              @relation(fields: [payRunId, organizationId], references: [id, organizationId], onDelete: Cascade)
  sourceFile          SourceFile          @relation(fields: [sourceFileId], references: [id], onDelete: Cascade)
  payComponents       EmployeePayComponent[]
  sourceRowRefs       SourceRowRef[]
  currentEmployeeMatch EmployeeMatch?     @relation("CurrentEmployeeMatch")
  previousEmployeeMatches EmployeeMatch[] @relation("PreviousEmployeeMatch")
  ruleResults         RuleResult[]

  @@index([organizationId, payRunId, recordScope])
  @@index([organizationId, payRunId, reviewSnapshotVersion, recordScope])
  @@index([sourceFileId, recordScope])
  @@index([clientId, payRunId])
  @@unique([sourceFileId, reviewSnapshotVersion, recordScope, sourceRowNumber])
}

model EmployeePayComponent {
  id                  String                       @id @default(cuid())
  organizationId      String
  clientId            String
  payRunId            String
  sourceFileId        String
  employeeRunRecordId String
  componentCode       String
  componentLabel      String
  category            EmployeePayComponentCategory
  amount              Decimal                      @db.Decimal(18, 2)
  quantity            Decimal?                     @db.Decimal(18, 4)
  unitRate            Decimal?                     @db.Decimal(18, 4)
  createdAt           DateTime                     @default(now())
  updatedAt           DateTime                     @updatedAt
  organization        Organization                 @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client              Client                       @relation(fields: [clientId, organizationId], references: [id, organizationId], onDelete: Cascade)
  payRun              PayRun                       @relation(fields: [payRunId, organizationId], references: [id, organizationId], onDelete: Cascade)
  sourceFile          SourceFile                   @relation(fields: [sourceFileId], references: [id], onDelete: Cascade)
  employeeRunRecord   EmployeeRunRecord            @relation(fields: [employeeRunRecordId], references: [id], onDelete: Cascade)
  sourceRowRefs       SourceRowRef[]
  ruleResults         RuleResult[]

  @@index([employeeRunRecordId, category])
  @@index([organizationId, payRunId])
  @@index([sourceFileId])
}

model SourceRowRef {
  id                   String               @id @default(cuid())
  organizationId       String
  clientId             String
  payRunId             String
  sourceFileId         String
  employeeRunRecordId  String?
  employeePayComponentId String?
  sheetName            String?
  rowNumber            Int
  columnHeader         String?
  columnValue          String?
  canonicalFieldKey    String?
  createdAt            DateTime             @default(now())
  organization         Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client               Client               @relation(fields: [clientId, organizationId], references: [id, organizationId], onDelete: Cascade)
  payRun               PayRun               @relation(fields: [payRunId, organizationId], references: [id, organizationId], onDelete: Cascade)
  sourceFile           SourceFile           @relation(fields: [sourceFileId], references: [id], onDelete: Cascade)
  employeeRunRecord    EmployeeRunRecord?   @relation(fields: [employeeRunRecordId], references: [id], onDelete: Cascade)
  employeePayComponent EmployeePayComponent? @relation(fields: [employeePayComponentId], references: [id], onDelete: Cascade)

  @@index([organizationId, payRunId, rowNumber])
  @@index([sourceFileId, rowNumber])
  @@index([employeeRunRecordId])
  @@index([employeePayComponentId])
}

model EmployeeMatch {
  id                        String              @id @default(cuid())
  organizationId            String
  clientId                  String
  payRunId                  String
  currentEmployeeRunRecordId String             @unique
  previousEmployeeRunRecordId String?           @unique
  matchMethod               EmployeeMatchMethod
  createdAt                 DateTime            @default(now())
  updatedAt                 DateTime            @updatedAt
  organization              Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client                    Client              @relation(fields: [clientId, organizationId], references: [id, organizationId], onDelete: Cascade)
  payRun                    PayRun              @relation(fields: [payRunId, organizationId], references: [id, organizationId], onDelete: Cascade)
  currentEmployeeRunRecord  EmployeeRunRecord   @relation("CurrentEmployeeMatch", fields: [currentEmployeeRunRecordId], references: [id], onDelete: Cascade)
  previousEmployeeRunRecord EmployeeRunRecord?  @relation("PreviousEmployeeMatch", fields: [previousEmployeeRunRecordId], references: [id], onDelete: SetNull)
  ruleResults               RuleResult[]

  @@index([organizationId, payRunId])
  @@index([clientId, payRunId])
}

model RuleResult {
  id                    String              @id @default(cuid())
  organizationId        String
  clientId              String
  payRunId              String
  employeeRunRecordId   String
  employeePayComponentId String?
  employeeMatchId       String?
  ruleCode              String
  ruleVersion           String
  resultStatus          RuleResultStatus    @default(failed)
  severity              RuleResultSeverity
  ruleMessage           String
  details               Json?
  createdAt             DateTime            @default(now())
  organization          Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client                Client              @relation(fields: [clientId, organizationId], references: [id, organizationId], onDelete: Cascade)
  payRun                PayRun              @relation(fields: [payRunId, organizationId], references: [id, organizationId], onDelete: Cascade)
  employeeRunRecord     EmployeeRunRecord   @relation(fields: [employeeRunRecordId], references: [id], onDelete: Cascade)
  employeePayComponent  EmployeePayComponent? @relation(fields: [employeePayComponentId], references: [id], onDelete: SetNull)
  employeeMatch         EmployeeMatch?      @relation(fields: [employeeMatchId], references: [id], onDelete: SetNull)
  reviewException       ReviewException?

  @@index([organizationId, payRunId, ruleCode])
  @@index([employeeRunRecordId, severity])
  @@index([employeeMatchId])
}

model ReviewException {
  id             String                @id @default(cuid())
  organizationId String
  clientId       String
  payRunId       String
  ruleResultId   String                @unique
  reviewStatus   ReviewExceptionStatus @default(open)
  assigneeUserId String?
  resolutionNote String?
  resolvedAt     DateTime?
  resolvedByUserId String?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  organization   Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client         Client                @relation(fields: [clientId, organizationId], references: [id, organizationId], onDelete: Cascade)
  payRun         PayRun                @relation(fields: [payRunId, organizationId], references: [id, organizationId], onDelete: Cascade)
  ruleResult     RuleResult            @relation(fields: [ruleResultId], references: [id], onDelete: Cascade)
  comments       ExceptionComment[]

  @@index([organizationId, payRunId, reviewStatus])
  @@index([clientId, payRunId])
}

model ExceptionComment {
  id                String          @id @default(cuid())
  organizationId    String
  clientId          String
  payRunId          String
  reviewExceptionId String
  authorUserId      String
  commentType       ExceptionCommentType @default(comment)
  body              String
  metadata          Json?
  createdAt         DateTime        @default(now())
  organization      Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client            Client          @relation(fields: [clientId, organizationId], references: [id, organizationId], onDelete: Cascade)
  payRun            PayRun          @relation(fields: [payRunId, organizationId], references: [id, organizationId], onDelete: Cascade)
  reviewException   ReviewException @relation(fields: [reviewExceptionId], references: [id], onDelete: Cascade)

  @@index([reviewExceptionId, createdAt])
  @@index([organizationId, payRunId])
}

model ApprovalEvent {
  id             String            @id @default(cuid())
  organizationId String
  clientId       String
  payRunId       String
  actorUserId    String
  eventType      ApprovalEventType
  reviewSnapshotVersion Int?
  note           String?
  createdAt      DateTime          @default(now())
  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client         Client            @relation(fields: [clientId, organizationId], references: [id, organizationId], onDelete: Cascade)
  payRun         PayRun            @relation(fields: [payRunId, organizationId], references: [id, organizationId], onDelete: Cascade)

  @@index([organizationId, payRunId, createdAt])
  @@index([organizationId, payRunId, reviewSnapshotVersion, createdAt])
  @@index([clientId, payRunId])
}

model ReviewProcessingRun {
  id                      String                  @id @default(cuid())
  organizationId          String
  clientId                String
  payRunId                String
  currentSourceFileId     String
  previousSourceFileId    String
  currentMappingSignature String
  previousMappingSignature String
  initiatedByUserId       String?
  triggerRunId            String?
  status                  ReviewProcessingRunStatus @default(queued)
  resultingSnapshotVersion Int?
  errorMessage            String?
  requestedAt             DateTime                @default(now())
  startedAt               DateTime?
  completedAt             DateTime?
  organization            Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client                  Client                  @relation(fields: [clientId, organizationId], references: [id, organizationId], onDelete: Cascade)
  payRun                  PayRun                  @relation(fields: [payRunId, organizationId], references: [id, organizationId], onDelete: Cascade)

  @@index([organizationId, payRunId, requestedAt])
  @@index([payRunId, status, requestedAt])
}

model JournalEntry {
  id               String       @id @default(cuid())
  organizationId   String
  clientId         String
  payRunId         String
  sourceFileId     String
  rowNumber        Int
  entryDate        String
  accountCode      String
  entryDescription String
  amount           Decimal      @db.Decimal(18, 2)
  createdAt        DateTime     @default(now())
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client           Client       @relation(fields: [clientId, organizationId], references: [id, organizationId], onDelete: Cascade)
  payRun           PayRun       @relation(fields: [payRunId, organizationId], references: [id, organizationId], onDelete: Cascade)
  sourceFile       SourceFile   @relation(fields: [sourceFileId], references: [id], onDelete: Cascade)

  @@unique([sourceFileId, rowNumber])
  @@index([organizationId, payRunId])
  @@index([sourceFileId])
}

model PaymentRecord {
  id                 String       @id @default(cuid())
  organizationId     String
  clientId           String
  payRunId           String
  sourceFileId       String
  rowNumber          Int
  employeeExternalId String
  employeeName       String
  paymentAmount      Decimal      @db.Decimal(18, 2)
  paymentReference   String?
  paymentDate        String?
  createdAt          DateTime     @default(now())
  organization       Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client             Client       @relation(fields: [clientId, organizationId], references: [id, organizationId], onDelete: Cascade)
  payRun             PayRun       @relation(fields: [payRunId, organizationId], references: [id, organizationId], onDelete: Cascade)
  sourceFile         SourceFile   @relation(fields: [sourceFileId], references: [id], onDelete: Cascade)

  @@unique([sourceFileId, rowNumber])
  @@index([organizationId, payRunId])
  @@index([sourceFileId])
}

model ReconciliationCheck {
  id               String                    @id @default(cuid())
  organizationId   String
  clientId         String
  payRunId         String
  sourceFileId     String
  checkKind        ReconciliationCheckKind
  status           ReconciliationCheckStatus
  payrollAmount    Decimal                   @db.Decimal(18, 2)
  comparisonAmount Decimal                   @db.Decimal(18, 2)
  varianceAmount   Decimal                   @db.Decimal(18, 2)
  toleranceAmount  Decimal                   @db.Decimal(18, 2)
  details          Json?
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt
  organization     Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client           Client                    @relation(fields: [clientId, organizationId], references: [id, organizationId], onDelete: Cascade)
  payRun           PayRun                    @relation(fields: [payRunId, organizationId], references: [id, organizationId], onDelete: Cascade)
  sourceFile       SourceFile                @relation(fields: [sourceFileId], references: [id], onDelete: Cascade)

  @@unique([sourceFileId, checkKind])
  @@index([organizationId, payRunId, status])
  @@index([clientId, payRunId, checkKind])
}
